/* =============================================================================
   SIAV - Plans Modal V4.0 - CSS
   Design Minimalista & Profissional | Mobile-First | Foco em Conversão
   ============================================================================= */

/* =============================================================================
   ROOT VARIABLES
   ============================================================================= */
:root {
  /* Colors */
  --color-primary: #dc2626;
  --color-secondary: #1a1a1a;
  --color-background: #ffffff;
  --color-text-primary: #111827;
  --color-text-secondary: #374151;
  --color-text-tertiary: #6b7280;
  --color-border: #e5e7eb;
  --color-border-dark: #d1d5db;
  --color-highlight-bg: #fafafa;
  --color-gradient-light: #f9fafb;

  /* Spacing */
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 1.5rem;
  --spacing-lg: 2rem;
  --spacing-xl: 3rem;
  --spacing-2xl: 4rem;

  /* Border Radius */
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --radius-xl: 1rem;

  /* Shadows */
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);

  /* Transitions */
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-smooth: 300ms cubic-bezier(0.4, 0, 0.2, 1);

  /* Typography */
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --font-weight-black: 900;

  /* Z-index */
  --z-modal: 9999;
  --z-header: 10000;
  --z-badge: 10;
}

/* =============================================================================
   RESET & BASE STYLES
   ============================================================================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* =============================================================================
   MODAL CONTAINER
   ============================================================================= */
.plans-modal {
  display: none; /* Oculto por padrão */
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background-color: var(--color-background);
  z-index: var(--z-modal);
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

.plans-modal.show {
  display: block; /* Visível quando tem a classe .show */
}

.plans-modal.hidden {
  display: none;
}

/* =============================================================================
   MODAL HEADER (STICKY)
   ============================================================================= */
.modal-header {
  position: sticky;
  top: 0;
  width: 100%;
  background-color: var(--color-background);
  border-bottom: 1px solid var(--color-border);
  z-index: var(--z-header);
  padding: var(--spacing-md) var(--spacing-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.modal-header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: var(--spacing-md);
}

.close-modal {
  background: none;
  border: none;
  font-size: 1.75rem;
  color: var(--color-text-tertiary);
  cursor: pointer;
  padding: var(--spacing-xs);
  line-height: 1;
  transition: color var(--transition-fast);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
}

.close-modal:hover {
  color: var(--color-text-primary);
  background-color: var(--color-highlight-bg);
}

.close-modal:active {
  transform: scale(0.95);
}

/* =============================================================================
   BILLING TOGGLE
   ============================================================================= */
.billing-toggle {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-sm);
  background-color: var(--color-highlight-bg);
  padding: 0.375rem;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
}

.billing-toggle button {
  padding: 0.625rem 1.25rem;
  background: none;
  border: none;
  color: var(--color-text-secondary);
  font-size: 0.9375rem;
  font-weight: var(--font-weight-medium);
  cursor: pointer;
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
  white-space: nowrap;
  position: relative;
}

.billing-toggle button.active {
  background-color: var(--color-secondary);
  color: var(--color-background);
  box-shadow: var(--shadow-sm);
}

.billing-toggle button:not(.active):hover {
  color: var(--color-text-primary);
  background-color: rgba(0, 0, 0, 0.03);
}

.save-badge {
  position: absolute;
  top: -0.5rem;
  right: -0.5rem;
  background-color: var(--color-primary);
  color: var(--color-background);
  font-size: 0.625rem;
  font-weight: var(--font-weight-bold);
  padding: 0.125rem 0.375rem;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  z-index: var(--z-badge);
  letter-spacing: 0.025em;
  box-shadow: var(--shadow-md);
}

/* =============================================================================
   MODAL CONTENT
   ============================================================================= */
.modal-content {
  max-width: 1200px;
  margin: 0 auto;
  padding: var(--spacing-xl) var(--spacing-sm);
}

/* =============================================================================
   PLANS GRID
   ============================================================================= */
.plans-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-2xl);
}

/* =============================================================================
   PLAN CARD BASE
   ============================================================================= */
.plan-card {
  background-color: var(--color-background);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  transition: all var(--transition-smooth);
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.plan-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

/* =============================================================================
   PLAN CARD VARIANTS
   ============================================================================= */

/* Gratuito - Minimal Style */
.plan-card.free {
  border-color: var(--color-border-dark);
}

.plan-card.free:hover {
  transform: none;
  box-shadow: var(--shadow-sm);
}

/* Estudante - Standard Style */
.plan-card.student {
  /* Uses default styling */
}

/* Profissional - HIGHLIGHTED */
.plan-card.professional {
  border: 2px solid var(--color-secondary);
  background-color: var(--color-highlight-bg);
  box-shadow: var(--shadow-md);
}

.plan-card.professional:hover {
  transform: scale(1.02);
  box-shadow: var(--shadow-xl);
}

/* Vitalício - PREMIUM */
.plan-card.lifetime {
  background: linear-gradient(135deg, var(--color-secondary) 0%, #2d2d2d 100%);
  border-color: var(--color-secondary);
  color: var(--color-background);
}

.plan-card.lifetime * {
  color: var(--color-background);
}

.plan-card.lifetime .plan-features li {
  color: rgba(255, 255, 255, 0.9);
}

.plan-card.lifetime .plan-features .checkmark {
  color: var(--color-primary);
}

.plan-card.lifetime:hover {
  transform: scale(1.02);
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
}

/* =============================================================================
   PLAN BADGE
   ============================================================================= */
.plan-badge {
  position: absolute;
  top: -0.75rem;
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--color-primary);
  color: var(--color-background);
  font-size: 0.75rem;
  font-weight: var(--font-weight-bold);
  padding: 0.375rem 1rem;
  border-radius: var(--radius-lg);
  white-space: nowrap;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  box-shadow: var(--shadow-md);
  z-index: var(--z-badge);
}

/* =============================================================================
   PLAN HEADER
   ============================================================================= */
.plan-header {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.plan-name {
  font-size: 1.5rem;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.plan-card.lifetime .plan-name {
  color: var(--color-background);
}

.plan-description {
  font-size: 0.9375rem;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.plan-card.lifetime .plan-description {
  color: rgba(255, 255, 255, 0.8);
}

/* =============================================================================
   PLAN PRICING
   ============================================================================= */
.plan-pricing {
  text-align: center;
  margin-bottom: var(--spacing-lg);
  padding: var(--spacing-md) 0;
}

.price-container {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.25rem;
  margin-bottom: var(--spacing-xs);
}

.currency {
  font-size: 1.5rem;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-secondary);
}

.plan-card.lifetime .currency {
  color: var(--color-background);
}

.price {
  font-size: 4.5rem;
  font-weight: var(--font-weight-black);
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--color-text-primary);
}

.plan-card.lifetime .price {
  color: var(--color-background);
}

.billing-period {
  font-size: 1rem;
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}

.plan-card.lifetime .billing-period {
  color: rgba(255, 255, 255, 0.8);
}

.original-price {
  font-size: 1.125rem;
  color: var(--color-text-tertiary);
  text-decoration: line-through;
  opacity: 0.7;
}

.plan-card.lifetime .original-price {
  color: rgba(255, 255, 255, 0.6);
}

.savings-text {
  font-size: 0.875rem;
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  margin-top: var(--spacing-xs);
}

/* =============================================================================
   PLAN FEATURES
   ============================================================================= */
.plan-features {
  flex: 1;
  margin-bottom: var(--spacing-lg);
}

.plan-features ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
  color: var(--color-text-secondary);
  font-size: 0.9375rem;
  line-height: 1.6;
}

.plan-features .checkmark {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  font-size: 1.125rem;
  flex-shrink: 0;
  margin-top: 0.125rem;
}

.plan-features li strong {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.plan-card.lifetime .plan-features li strong {
  color: var(--color-background);
}

/* =============================================================================
   PLAN CTA
   ============================================================================= */
.plan-cta {
  width: 100%;
  padding: 1rem 2rem;
  font-size: 1rem;
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-lg);
  border: none;
  cursor: pointer;
  transition: all var(--transition-base);
  text-align: center;
  letter-spacing: 0.025em;
}

.plan-cta:active {
  transform: scale(0.98);
}

/* Free CTA */
.plan-card.free .plan-cta {
  background-color: var(--color-background);
  color: var(--color-text-primary);
  border: 2px solid var(--color-border-dark);
}

.plan-card.free .plan-cta:hover {
  background-color: var(--color-highlight-bg);
  border-color: var(--color-text-secondary);
}

/* Student CTA */
.plan-card.student .plan-cta {
  background-color: #3b82f6;
  color: var(--color-background);
  box-shadow: var(--shadow-md);
}

.plan-card.student .plan-cta:hover {
  background-color: #2563eb;
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* Professional CTA */
.plan-card.professional .plan-cta {
  background-color: var(--color-secondary);
  color: var(--color-background);
  box-shadow: var(--shadow-md);
}

.plan-card.professional .plan-cta:hover {
  background-color: #000000;
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* Lifetime CTA */
.plan-card.lifetime .plan-cta {
  background-color: var(--color-background);
  color: var(--color-secondary);
  box-shadow: var(--shadow-lg);
  font-weight: var(--font-weight-bold);
}

.plan-card.lifetime .plan-cta:hover {
  background-color: var(--color-primary);
  color: var(--color-background);
  transform: translateY(-2px);
  box-shadow: var(--shadow-xl);
}

/* =============================================================================
   GUARANTEE SECTION
   ============================================================================= */
.guarantee-section {
  background: linear-gradient(to bottom, var(--color-gradient-light), var(--color-background));
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  text-align: center;
  margin-bottom: var(--spacing-xl);
  border: 1px solid var(--color-border);
}

.guarantee-icon {
  font-size: 3rem;
  margin-bottom: var(--spacing-md);
  color: var(--color-primary);
}

.guarantee-title {
  font-size: 1.5rem;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.guarantee-text {
  font-size: 1rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
  max-width: 600px;
  margin: 0 auto;
}

/* =============================================================================
   TESTIMONIALS SECTION
   ============================================================================= */
.testimonials-section {
  margin-bottom: var(--spacing-xl);
}

.testimonials-title {
  font-size: 1.75rem;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.testimonials-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--spacing-lg);
}

.testimonial-card {
  background-color: var(--color-background);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  transition: all var(--transition-smooth);
}

.testimonial-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.testimonial-text {
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: var(--spacing-md);
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.author-name {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-size: 0.9375rem;
}

.author-role {
  font-size: 0.875rem;
  color: var(--color-text-tertiary);
}

/* =============================================================================
   TOAST NOTIFICATIONS (Mobile)
   ============================================================================= */
.toast {
  position: fixed;
  bottom: var(--spacing-lg);
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--color-secondary);
  color: var(--color-background);
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  font-size: 0.9375rem;
  font-weight: var(--font-weight-medium);
  box-shadow: var(--shadow-xl);
  z-index: calc(var(--z-modal) + 1);
  max-width: 90%;
  text-align: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-smooth);
}

.toast.show {
  opacity: 1;
  pointer-events: auto;
}

/* =============================================================================
   RESPONSIVE - TABLET (768px - 1024px)
   ============================================================================= */
@media (min-width: 768px) {
  .modal-header {
    padding: var(--spacing-lg) var(--spacing-md);
  }

  .modal-content {
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .plans-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .testimonials-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .plan-card {
    padding: var(--spacing-lg);
  }

  .price {
    font-size: 4rem;
  }
}

/* =============================================================================
   RESPONSIVE - DESKTOP (1024px+)
   ============================================================================= */
@media (min-width: 1024px) {
  .modal-content {
    padding: var(--spacing-2xl) var(--spacing-lg);
  }

  .plans-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .testimonials-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .plan-card {
    padding: var(--spacing-xl);
  }

  .price {
    font-size: 4.5rem;
  }
}

/* =============================================================================
   RESPONSIVE - LARGE DESKTOP (1200px+)
   ============================================================================= */
@media (min-width: 1200px) {
  .plans-grid {
    gap: var(--spacing-lg);
  }
}

/* =============================================================================
   MOBILE OPTIMIZATIONS (<768px)
   ============================================================================= */
@media (max-width: 767px) {
  /* Hide sections on mobile */
  .testimonials-section,
  .guarantee-section {
    display: none;
  }

  .modal-header {
    padding: var(--spacing-sm);
  }

  .modal-header-content {
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .close-modal {
    position: absolute;
    right: var(--spacing-sm);
    top: var(--spacing-sm);
  }

  .billing-toggle {
    width: 100%;
    justify-content: center;
  }

  .billing-toggle button {
    flex: 1;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
  }

  .save-badge {
    font-size: 0.5625rem;
    padding: 0.125rem 0.25rem;
  }

  .modal-content {
    padding: var(--spacing-md) var(--spacing-sm);
  }

  .plans-grid {
    gap: var(--spacing-md);
  }

  .plan-card {
    padding: var(--spacing-md);
  }

  .plan-badge {
    font-size: 0.6875rem;
    padding: 0.3125rem 0.75rem;
  }

  .plan-name {
    font-size: 1.25rem;
  }

  .price {
    font-size: 3rem;
  }

  .currency {
    font-size: 1.25rem;
  }

  .billing-period {
    font-size: 0.875rem;
  }

  .plan-features li {
    font-size: 0.875rem;
    padding: 0.625rem 0;
  }

  .plan-cta {
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
  }
}

/* =============================================================================
   ACCESSIBILITY
   ============================================================================= */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Focus states for keyboard navigation */
button:focus-visible,
.plan-cta:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

/* =============================================================================
   PRINT STYLES
   ============================================================================= */
@media print {
  .modal-header,
  .close-modal,
  .billing-toggle {
    display: none;
  }

  .plans-grid {
    display: block;
  }

  .plan-card {
    page-break-inside: avoid;
    margin-bottom: var(--spacing-lg);
  }
}

/* =============================================================================
   UTILITIES
   ============================================================================= */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

.no-scroll {
  overflow: hidden;
}

/* =============================================================================
   ANIMATIONS
   ============================================================================= */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.plans-modal {
  animation: fadeIn var(--transition-smooth);
}

.plan-card {
  animation: slideUp var(--transition-smooth);
  animation-fill-mode: both;
}

.plan-card:nth-child(1) {
  animation-delay: 0ms;
}

.plan-card:nth-child(2) {
  animation-delay: 75ms;
}

.plan-card:nth-child(3) {
  animation-delay: 150ms;
}

.plan-card:nth-child(4) {
  animation-delay: 225ms;
}
